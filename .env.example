# ============================================================
# NVIDIA Resource Suite — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- NVIDIA NIM (required for AI inference) ---
# Get your key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# --- NVIDIA Omniverse ---
OMNIVERSE_NUCLEUS_URL=omniverse://localhost
OMNIVERSE_FARM_URL=http://localhost:8222
OMNIVERSE_COMPOSER_URL=http://localhost:8011

# --- NVIDIA Triton Inference Server ---
TRITON_URL=http://localhost:8000
TRITON_GRPC_URL=localhost:8001

# --- NVIDIA Earth-2 ---
EARTH2_API_URL=https://api.earth2.nvidia.com
EARTH2_API_KEY=

# --- NVIDIA CloudXR ---
CLOUDXR_SERVER_URL=

# --- NGC (NVIDIA GPU Cloud) ---
NGC_API_KEY=

# --- Service Ports ---
API_PORT=7760
DEEPFLEX_URL=http://localhost:8000
ARGUS_URL=http://localhost:7700
VR_ROOM_URL=http://localhost:7791

# --- Database (optional — for progress tracking) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
