# NVIDIA Resource Suite — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# NVIDIA API Key — get free at https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=nvapi-REPLACE_WITH_YOUR_KEY

# NVIDIA NIM base URL (default is the hosted API)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Omniverse (optional — for local Omniverse installation)
OMNIVERSE_NUCLEUS_URL=omniverse://localhost
OMNIVERSE_FARM_URL=http://localhost:8222
OMNIVERSE_KIT_SDK_PATH=/opt/ov/kit

# Service configuration
NVIDIA_SUITE_PORT=7760

# SAP integration
DEEPFLEX_BASE_URL=http://localhost:8000
